# -----------------------------
# Security / Secrets (never commit)
# -----------------------------
.env
.env.*
**/.env
**/.env.*
!.env.example
!**/.env.example
!.env.sample
!**/.env.sample

# Certificates and private keys
*.pem
*.key
*.p12
*.pfx
*.crt
*.csr
*.jks
*.keystore

# Cloud / credential folders
.aws/
.azure/
.gcp/

# -----------------------------
# Python
# -----------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# Tool caches and test artifacts
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/
.hypothesis/
.tox/
.nox/

# Coverage / reports
.coverage
.coverage.*
htmlcov/

# Packaging / build outputs
build/
dist/
site/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/

# -----------------------------
# Node / Next.js
# -----------------------------
node_modules/
.pnpm-store/
.npm/
.yarn/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz
.parcel-cache/
.turbo/

# Next.js artifacts
.next/
out/
.vercel/
*.tsbuildinfo

# JS test coverage
coverage/

