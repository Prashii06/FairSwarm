{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 60,
    "startCommand": "uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000} --workers 2"
  }
}
